# ================================================================
# CortexAgent — Environment Configuration Template
# ================================================================
# 1. Copy this file: cp .env.example .env
# 2. Fill in the REQUIRED values below
# 3. Save. Never commit .env to git (it's in .gitignore)
# ================================================================

# ================================================================
# REQUIRED — LLM PROVIDER KEYS
# ================================================================

# Anthropic API key — powers the Critic, Writer, and RAGAS judge.
# Get one at: https://console.anthropic.com/
ANTHROPIC_API_KEY=REPLACE_ME_ANTHROPIC_KEY

# Google AI Studio API key — powers the Researcher, Analyst, and Self-RAG.
# Get one at: https://aistudio.google.com/apikey
# Free tier has daily quota; paid tier is $0.10/1M input on gemini-2.5-flash-lite.
GEMINI_API_KEY=REPLACE_ME_GEMINI_KEY

# Groq API key — powers the fallback tier (Llama 3.3 70B at ~200ms latency).
# Get one at: https://console.groq.com/
GROQ_API_KEY=REPLACE_ME_GROQ_KEY

# ================================================================
# REQUIRED — SEC EDGAR IDENTITY
# ================================================================
# SEC EDGAR requires a User-Agent string identifying who's making requests.
# No signup needed — just use your real name and email.
# Format: "Your Name your.email@example.com"
SEC_IDENTITY=Your Name your.email@example.com

# ================================================================
# OPTIONAL — MODEL ROUTING (smart defaults shown)
# ================================================================
# Each agent routes to the cheapest capable model.
# See docs/07_cost_engineering.md for model-selection rationale.

RESEARCHER_MODEL=gemini-2.5-flash-lite
ANALYST_MODEL=gemini-2.5-flash-lite
WRITER_MODEL=claude-haiku-4-5
CRITIC_MODEL=claude-sonnet-4-5
SELFRAG_MODEL=gemini-2.5-flash-lite
RAGAS_JUDGE_MODEL=claude-sonnet-4-5

# Local sentence-transformers embeddings — free, runs on CPU.
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ================================================================
# OPTIONAL — STORAGE
# ================================================================
# Where ChromaDB persists its vector store on disk.
CHROMA_PERSIST_DIR=./chroma_db

# Only needed if you wire up the MCP database_query tool against Postgres.
POSTGRES_URL=postgresql://cortex:cortex@localhost:5432/cortexagent

# Only needed if you add Redis caching (future work).
REDIS_URL=redis://localhost:6379

# ================================================================
# OPTIONAL — RAGAS QUALITY GATE THRESHOLDS
# ================================================================
# These block PR merges in GitHub Actions if RAGAS scores fall below.
# See docs/05_evaluation.md for rationale.

RAGAS_FAITHFULNESS_THRESHOLD=0.40
RAGAS_ANSWER_RELEVANCE_THRESHOLD=0.20
RAGAS_CONTEXT_PRECISION_THRESHOLD=0.25

# ================================================================
# OPTIONAL — LOGGING
# ================================================================
LOG_LEVEL=INFO
