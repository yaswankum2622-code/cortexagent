# === LLM Provider Keys ===
ANTHROPIC_API_KEY=your_anthropic_key_here
GEMINI_API_KEY=your_gemini_key_here
GROQ_API_KEY=your_groq_key_here

# === SEC EDGAR Identity (required, format: "Name email@example.com") ===
SEC_IDENTITY=Your Name your.email@example.com

# === Per-Agent Model Routing ===
RESEARCHER_MODEL=gemini-2.5-flash
ANALYST_MODEL=gemini-2.5-flash
WRITER_MODEL=claude-sonnet-4-5
CRITIC_MODEL=claude-sonnet-4-5
SELFRAG_MODEL=gemini-2.5-flash
RAGAS_JUDGE_MODEL=claude-sonnet-4-5
# Optional Groq model pins
# GROQ_PRIMARY_MODEL=llama-3.3-70b-versatile
# GROQ_FAST_MODEL=llama-3.1-8b-instant

# === Embedding Model (local, free) ===
EMBEDDING_MODEL=all-MiniLM-L6-v2

# === Storage ===
CHROMA_PERSIST_DIR=./chroma_db
POSTGRES_URL=postgresql://cortex:cortex@localhost:5432/cortexagent
REDIS_URL=redis://localhost:6379

# === RAGAS Quality Thresholds (block CI if not met) ===
RAGAS_FAITHFULNESS_THRESHOLD=0.85
RAGAS_ANSWER_RELEVANCE_THRESHOLD=0.80
RAGAS_CONTEXT_PRECISION_THRESHOLD=0.75

# === Logging ===
LOG_LEVEL=INFO
